# ---------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------

# Base URL of the .NET API. Required — the app will throw at startup if unset.
VITE_API_BASE_URL=http://localhost:5216

# ---------------------------------------------------------------
# .NET API
# ---------------------------------------------------------------

# SQL Server connection string.
ConnectionStrings__DefaultConnection='Server=localhost,1433;Database=keeper;User Id=sa;Password=<your-sa-password>;TrustServerCertificate=True;Encrypt=False'

# Resend API token — required for production email sending.
# Obtain from https://resend.com/api-keys
# Not needed in development (DevelopmentAuthCodeSender logs codes to console instead).
RESEND_APITOKEN=

# Base URL of the ML Pipelines service.
MLPipelines__BaseUrl=http://localhost:8000

# Sender address for auth emails.
AuthEmail__FromAddress=onboarding@resend.dev

# Allowed CORS origins (add one entry per origin, incrementing the index).
# In Azure App Settings use Cors__AllowedOrigins__0, Cors__AllowedOrigins__1, etc.
# In development this defaults to http://localhost:5173 when left unset.
Cors__AllowedOrigins__0=https://your-app.vercel.app
