root = true

[*.cs]
# Indentation
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# CA1848: Use LoggerMessage delegates for performance.
# Suppressed: the boilerplate is excessive for a small API where logging is infrequent.
dotnet_diagnostic.CA1848.severity = none
